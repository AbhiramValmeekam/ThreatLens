# ============================================================
# ThreatLens Backend Environment Variables
# ============================================================

# Google OAuth Client ID (from Google Developer Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Session JWT Secret (use a secure random string)
JWT_SECRET_KEY=threatlens-super-secure-jwt-key-9876543210-abcdef

# Database URL override (optional, defaults to sqlite:///data/prompt_injection.db)
# DATABASE_URL=sqlite:///data/prompt_injection.db
